<?xml version="1.0" encoding="utf-8"?>
<robot name="antt_t1">
  <link name="world"/>

  <link name="tbar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.08 0.06"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 -0.60" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 1.20"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.15 0.08 0.06"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.60" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 1.20"/>
      </geometry>
    </collision>
  </link>

  <joint name="world_to_tbar" type="fixed">
    <parent link="world"/>
    <child link="tbar_link"/>
    <origin xyz="0 0 1.2" rpy="0 0 0"/>
  </joint>

  <!-- Mount arms at horizontal beam ends (beam length 0.15 m => half-length 0.075 m) -->
  <joint name="tbar_to_left_base" type="fixed">
    <parent link="tbar_link"/>
    <child link="left_base_link"/>
    <origin xyz="0.075 0 0" rpy="1.5707963267948966 -1.5707963267948966 1.5707963267948966"/>
  </joint>

  <joint name="tbar_to_right_base" type="fixed">
